<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <system.webServer>

    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options"        value="SAMEORIGIN" />
      </customHeaders>
    </httpProtocol>

    <rewrite>
      <rules>
        <rule name="redirect-about" stopProcessing="true">
          <match url="^about/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/company.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-about-us" stopProcessing="true">
          <match url="^about-us/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/company.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-contact" stopProcessing="true">
          <match url="^contact/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/company.html#contact" redirectType="Permanent" />
        </rule>
        <rule name="redirect-contact-us" stopProcessing="true">
          <match url="^contact-us/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/company.html#contact" redirectType="Permanent" />
        </rule>
        <rule name="redirect-careers" stopProcessing="true">
          <match url="^careers/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/company.html#careers" redirectType="Permanent" />
        </rule>
        <rule name="redirect-solutions" stopProcessing="true">
          <match url="^solutions/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/solutions.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-pricing" stopProcessing="true">
          <match url="^pricing/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/pricing.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-how-it-works" stopProcessing="true">
          <match url="^how-it-works/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/how-it-works.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-lms" stopProcessing="true">
          <match url="^lms/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/lms.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-ai-video-platform" stopProcessing="true">
          <match url="^ai-video-platform/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/AI-video-platform.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-ppt-to-scorm" stopProcessing="true">
          <match url="^ppt-to-scorm/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/ppt-to-scorm.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-privacy-policy" stopProcessing="true">
          <match url="^privacy-policy/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/privacy.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-privacy" stopProcessing="true">
          <match url="^privacy/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/privacy.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-terms" stopProcessing="true">
          <match url="^terms/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/terms.html" redirectType="Permanent" />
        </rule>
        <rule name="redirect-terms-of-service" stopProcessing="true">
          <match url="^terms-of-service/?$" ignoreCase="true" />
          <action type="Redirect" url="/pages/terms.html" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>

</configuration>
